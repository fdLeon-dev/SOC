# ============================================================
# DefenseOS - Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Application ---
APP_NAME="DefenseOS"
APP_ENV="development"          # development | production
DEBUG=true
SECRET_KEY="CHANGE_ME_USE_openssl_rand_hex_32"
API_V1_PREFIX="/api/v1"

# --- JWT Tokens ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM="HS256"

# --- Database ---
# SQLite (default for local lab)
DATABASE_URL="sqlite+aiosqlite:///./defenseos.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/defenseos"

# --- CORS (Frontend URL) ---
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# --- First Admin User (auto-created on startup) ---
FIRST_ADMIN_EMAIL="admin@example.com"
FIRST_ADMIN_PASSWORD="Admin1234!"
FIRST_ADMIN_USERNAME="admin"

# --- Monitoring Intervals (seconds) ---
METRICS_INTERVAL=5
LOG_WATCH_INTERVAL=2
NETWORK_SCAN_INTERVAL=30
PROCESS_SCAN_INTERVAL=10
FILE_INTEGRITY_INTERVAL=60

# --- Log Paths to Monitor ---
LOG_PATHS="/var/log/syslog,/var/log/auth.log,/var/log/kern.log"

# --- Alert Thresholds ---
CPU_ALERT_THRESHOLD=85.0
MEMORY_ALERT_THRESHOLD=90.0
DISK_ALERT_THRESHOLD=90.0

# --- PDF / Export ---
REPORT_OUTPUT_DIR="./reports"

# --- Notifications (optional) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
ALERT_EMAIL_TO=""
